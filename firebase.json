{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "secretEnvironmentVariables": [
        {
          "key": "TWITCH_CLIENT_ID",
          "secret": "twitch-client-id"
        },
        {
          "key": "TWITCH_CLIENT_SECRET",
          "secret": "twitch-client-secret"
        },
        {
          "key": "JWT_SECRET_KEY",
          "secret": "jwt-secret-key"
        },
        {
          "key": "WAVESPEED_API_KEY",
          "secret": "WAVESPEED_API_KEY"
        },
        {
          "key": "302_KEY",
          "secret": "302_KEY"
        }
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src/**/*.ts",
        "index.ts",
        "**/*.test.ts",
        "**/__tests__/**",
        "tsconfig.json",
        "jest.config.js",
        "coverage"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "predeploy": [
      "npm run build:frontend"
    ],
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local",
      ".env",
      "public/js/**/*.ts",
      "public/js/**/*.js.map"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "webUi"
      },
      {
        "source": "/auth/**",
        "function": "webUi"
      },
      {
        "source": "/s/**",
        "function": "webUi"
      }
    ]
  }
}